{
  "database": {
    "@konsumation/db-level": "db"
  },
  "auth": {
    "users": {
      "user1": {
        "password": "start123",
        "entitlements": [
          "konsum",
          "konsum.category.get",
          "konsum.category.add",
          "konsum.category.modify",
          "konsum.category.delete",
          "konsum.value.get",
          "konsum.value.add",
          "konsum.value.delete",
          "konsum.meter.get",
          "konsum.meter.add",
          "konsum.meter.modify",
          "konsum.meter.delete",
          "konsum.note.get",
          "konsum.note.add",
          "konsum.note.modify",
          "konsum.note.delete"
        ]
      },
      "admin": {
        "password": "start123",
        "entitlements": [
          "konsum", 
          "konsum.admin.backup",
          "konsum.admin.stop",
          "konsum.admin.reload",
          "konsum.admin.token"
        ]
      }
    },
    "jwt": {
      "options": {
        "expiresIn": "1h",
        "audience": "konsum"
      },
      "public": "${document('demo.rsa.pub')}",
      "private": "${document('demo.rsa')}"
    }
  },
  "http": {
    "port": 12345
  },
  "meterPhoto": {
    "enabled": "${first(env.METER_PHOTO_ENABLED, false)}",
    "vision": {
      "apiKey": "${first(env.VISION_API_KEY, env.GOOGLE_AI_STUDIO_API_KEY, '')}",
      "apiEndpoint": "${first(env.VISION_API_ENDPOINT, 'https://generativelanguage.googleapis.com/v1beta')}",
      "model": "${first(env.VISION_API_MODEL, 'gemini-2.0-flash')}",
      "prompt": "${first(env.VISION_API_PROMPT, 'Read the meter display in this image and return only the numeric value with decimal point. No units, no text, just the number.')}",
      "maxOutputTokens": 64,
      "temperature": 0
    }
  }
}
